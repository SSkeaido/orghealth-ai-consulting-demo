{
  "name": "orghealth-workbench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/local-api.mjs",
    "dev:local": "concurrently --kill-others --names WEB,MODEL \"pnpm dev\" \"pnpm dev:api\"",
    "capture:ppt": "node scripts/capture-ppt-screenshots.mjs",
    "build": "tsc -b && vite build",
    "lint": "oxlint"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1"
  }
}
